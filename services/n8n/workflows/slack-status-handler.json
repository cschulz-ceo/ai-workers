    {
      "parameters": {
        "jsCode": "const modelsData = $('Ollama Models').first().json;\nconst psData = $('Ollama Running').first().json;\nconst n8nData = $('n8n Health').first().json;\nconst webhookBody = $('Webhook').first().json.body || {};\n\nconst allModels = modelsData.models || [];\nconst PERSONALITY_NAMES = ['kevin','jason','scaachi','christian','chidi'];\nconst personalities = allModels.filter(m =>\n  PERSONALITY_NAMES.some(p => m.name.startsWith(p))\n);\n\nconst running = psData.models || [];\nlet vramUsed = 0;\nlet runningNames = [];\nfor (const m of running) {\n  vramUsed += (m.size_vram || 0);\n  runningNames.push(m.name.split(':')[0]);\n}\nconst vramGB = (vramUsed / 1e9).toFixed(1);\n\nconst ollamaOk = allModels.length > 0;\nconst n8nOk = n8nData.status === 'ok';\n\nconst ollamaIcon = ollamaOk ? ':large_green_circle:' : ':red_circle:';\nconst n8nIcon = n8nOk ? ':large_green_circle:' : ':red_circle:';\nconst runningText = runningNames.length > 0\n  ? runningNames.join(', ') + ' (' + vramGB + 'GB VRAM)'\n  : 'none (models unloaded)';\n\nconst personalityList = personalities.map(m => m.name.split(':')[0]).join(', ') || 'none';\n\nconst now = new Date().toLocaleString('en-US', {\n  timeZone: 'America/New_York', hour12: true,\n  month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'\n});\n\nconst lines = [\n  '*ai-workers system status* \u2014 ' + now,\n  '',\n  ollamaIcon + ' *Ollama* \u2014 ' + allModels.length + ' models available',\n  '  Personalities: ' + personalityList,\n  '  In memory: ' + runningText,\n  '',\n  n8nIcon + ' *n8n* \u2014 ' + (n8nOk ? 'healthy' : 'DOWN'),\n  '  Tunnel: https://appendicular-wilson-looser.ngrok-free.dev',\n  '',\n  ':large_green_circle: *Open WebUI* \u2014 http://localhost:8080'\n];\n\nreturn [{ json: {\n  statusText: lines.join('\\n'),\n  responseUrl: webhookBody.response_url || ''\n}}];"
      },
