        "body": "={{ JSON.stringify({  files: [{ id: JSON.parse($('COM_Get Upload URL').first().json.data).file_id }],  channel_id: $('Poll Until Done').first().json.channelId,  initial_comment: ':sparkles: *Enhanced image*\\n_Upscaled + enhanced on RTX 5070 Ti_'}) }}",
        "options": {}
      },
      "id": "6995a0bf-de13-4884-b8b1-8e3368b34d29",
      "name": "COM_Complete Upload",
