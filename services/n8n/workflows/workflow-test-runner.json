              "name": "blocks",
              "value": "={{ JSON.stringify([\n  { type: 'header', text: { type: 'plain_text', text: 'Workflow Health Report' } },\n  { type: 'section', fields: [\n    { type: 'mrkdwn', text: '*Mode:* `' + $json.mode + '`' },\n    { type: 'mrkdwn', text: '*Passed:* ' + $json.pass },\n    { type: 'mrkdwn', text: '*Failed:* ' + $json.fail }\n  ]},\n  { type: 'divider' },\n  { type: 'section', text: { type: 'mrkdwn', text: $json.lines.substring(0, 2800) } },\n  { type: 'divider' },\n  { type: 'context', elements: [{ type: 'mrkdwn', text: $json.icon + ' *' + $json.summary + '*' }] }\n]) }}"
            }
          ]
