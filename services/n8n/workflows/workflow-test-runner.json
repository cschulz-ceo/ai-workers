      "id": "wtr-build-report-001",
      "name": "Build Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3760,
        160
      ],
      "parameters": {
        "jsCode": "// Collect all HTTP response results\n// n8n passes us the last node's output; we use node references to check each\nconst checks = [];\n\n// Helper to evaluate a test node result\nfunction evalNode(label, nodeData) {\n  try {\n    const code = nodeData?.json?.statusCode || nodeData?.statusCode || 0;\n    const ok = code >= 200 && code < 300;\n    return { label, ok, code };\n  } catch(e) {\n    return { label, ok: false, code: 0, err: String(e) };\n  }\n}\n\n// Fast tests\nchecks.push(evalNode('/ai-status',  $('Test /ai-status').first()));\nchecks.push(evalNode('/ai-diagnose',$('Test /ai-diagnose').first()));\n\n// Ollama tests (only if full mode)\nconst mode = $('Parse Request').first().json.mode;\nif (mode !== 'quick') {\n  checks.push(evalNode('/ai',     $('Test /ai').first()));\n  checks.push(evalNode('/news',   $('Test /news').first()));\n  checks.push(evalNode('/pm',     $('Test /pm').first()));\n  checks.push(evalNode('/3d',     $('Test /3d').first()));\n  checks.push(evalNode('/patent', $('Test /patent').first()));\n}\n\nconst pass  = checks.filter(c => c.ok).length;\nconst fail  = checks.filter(c => !c.ok).length;\nconst lines = checks.map(c => c.ok\n  ? `\u2705  *${c.label}*  \u2014 ack ${c.code}`\n  : `\u274c  *${c.label}*  \u2014 HTTP ${c.code}`\n);\n\n// Always-skip section\nlines.push('\u23ed\ufe0f  */image /video /enhance*  \u2014 Awaiting ComfyUI model download');\nlines.push('\u23ed\ufe0f  *The Council*  \u2014 Requires live Slack event');\n\nconst icon = fail === 0 ? ':white_check_mark:' : ':x:';\nconst summary = fail === 0\n  ? `${pass} workflows healthy`\n  : `${fail} FAILED \u2014 ${pass} passed`;\n\nreturn [{ json: {\n  pass, fail,\n  mode,\n  icon,\n  summary,\n  lines: lines.join('\\n'),\n  startedAt: $('Parse Request').first().json.startedAt,\n  completedAt: new Date().toISOString()\n}}];"
      }
    },
