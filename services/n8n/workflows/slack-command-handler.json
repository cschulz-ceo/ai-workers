    {
      "parameters": {
        "jsCode": "const ollamaResp = $input.first().json;\nconst parsed = $('Parse Command').first().json;\n\nconst content = ollamaResp.message?.content || 'No response from model.';\nconst MAX = 2800;\nconst truncated = content.length > MAX\n  ? content.slice(0, MAX) + '\\n_[response truncated]_'\n  : content;\n\nreturn [{ json: {\n  responseUrl: parsed.responseUrl,\n  agent: parsed.agent,\n  userId: parsed.userId,\n  slackPayload: JSON.stringify({\n    response_type: 'in_channel',\n    blocks: [\n      {\n        type: 'context',\n        elements: [{ type: 'mrkdwn', text: ':robot_face: *' + parsed.agent + '* responding to <@' + parsed.userId + '>' }]\n      },\n      {\n        type: 'section',\n        text: { type: 'mrkdwn', text: truncated }\n      }\n    ]\n  })\n}}];"
      },
